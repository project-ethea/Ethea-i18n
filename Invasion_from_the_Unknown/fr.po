#. [event]
#. [event]: id=Galas}
#: Invasion_from_the_Unknown/scenarios/19_Under_the_Sands.cfg:320
#: Invasion_from_the_Unknown/scenarios/18_Ashes_of_Wesmere.cfg:244
#: Invasion_from_the_Unknown/scenarios/18_Ashes_of_Wesmere.cfg:431
