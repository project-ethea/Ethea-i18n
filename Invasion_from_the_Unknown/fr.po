#: Invasion_from_the_Unknown/scenarios/11_Strike_on_Herthgar.cfg:5
#: Invasion_from_the_Unknown/macros/storytxt.cfg:263
msgid "Strike on Herthgar"
msgstr "Attaque sur Herthgar"

#. [side]: type=Chaos Lorekeeper, id=Armiza'ar
#: Invasion_from_the_Unknown/scenarios/11_Strike_on_Herthgar.cfg:139
msgid "Armiza’ar"
msgstr "Armiza'ar"

#. [side]: type=Dwarvish Explorer, id=Denathor
#: Invasion_from_the_Unknown/scenarios/11_Strike_on_Herthgar.cfg:159
msgid "Denathor"
msgstr "Denathor"

#. [side]: type=Chaos Soulhunter, id=Oddis
#: Invasion_from_the_Unknown/scenarios/11_Strike_on_Herthgar.cfg:198
msgid "Oddis"
msgstr "Oddis"

#. [side]: type=Hell Guardian, id=Gythrn
#: Invasion_from_the_Unknown/scenarios/11_Strike_on_Herthgar.cfg:221
msgid "Gythrn"
msgstr "Gythrn"

#. [side]: type=Chaos Cataphract, id=Alazar
#: Invasion_from_the_Unknown/scenarios/11_Strike_on_Herthgar.cfg:244
msgid "Alazar"
msgstr "Alazar"

#. [side]: type=Dwarvish Dragonguard, id=Furin
