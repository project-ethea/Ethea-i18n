#. Generator for Verlissh machine part names; see <https://wiki.wesnoth.org/Context-free_grammar> for the
#. syntax documentation.
#. .
#. Try to keep `structure_type` and `node_type` as short as possible, using abbreviations (WITHOUT dots)
#. if necessary. Bonus points if you use technical or obscure words for this.
#. .
#. The original English version uses the following abbreviated forms:
#. .
#. * Tr    = Trunk
#. * Br    = Branch
#. * Jnc   = Junction
#. * Co    = Core
#. * Le    = Leaf
#. * Rt    = Root
#. * Aux   = Auxiliary
#. * Lo    = Lower
#. * Up    = Upper
#. * Prt   = Port
#. * Ln    = Line
#. * Par   = Parallel
#. .
#. Because of issues with randomization (?), `number` and `upalpha` actually produce placeholders filled in
#. through a later step using Lua instead. Anywhere in the generated name where a `@` is found, an uppercase
#. Latin letter (English only) is substituted, while `%` is substituted with a Roman numeral (0-9).
#: Naia/lua/units.lua:41
msgid ""
"TRANSLATORS: the comment attached to this msgid applies to the next two "
"entries"
msgstr ""
"TRADUCTORES: el comentario adjunto a este msgstr se aplica a las siguientes "
"dos entradas."

#: Naia/lua/units.lua:43
msgid ""
"main={structure_type} {id}\n"
"\n"
"structure_type=Br|Jnc|Aux|Lo|Up|Ln|Par\n"
"\n"
"id={series}{unitno}|{series}{unitno_suffixed}\n"
"series={upalpha}|{upalpha}{upalpha}\n"
"unitno={number}{number}{number}{number}-{number}{number}\n"
"unitno_suffixed={number}{number}{number}{number}-{number}{suffix}\n"
"suffix=A|B|C|D|E|F\n"
"\n"
"number=%\n"
"upalpha=@\n"
msgstr ""
"main={structure_type} {id}\n"
"\n"
"structure_type=Br|Jnc|Aux|Lo|Up|Ln|Par\n"
"\n"
"id={series}{unitno}|{series}{unitno_suffixed}\n"
"series={upalpha}|{upalpha}{upalpha}\n"
"unitno={number}{number}{number}{number}-{number}{number}\n"
"unitno_suffixed={number}{number}{number}{number}-{number}{suffix}\n"
"suffix=A|B|C|D|E|F\n"
"\n"
"number=%\n"
"upalpha=@\n"

#: Naia/lua/units.lua:57
msgid ""
"main={node_type} {id}\n"
"\n"
"node_type=Co|Hub|Jnc|Aux|Rt|Tr|Le|Prt\n"
"\n"
"id={series}{unitno}|{series}{unitno}{suffix}\n"
"series={upalpha}|{upalpha}{upalpha}\n"
"unitno={number}-{number}{number}\n"
"suffix=A|B|C|D|E|F|α|β|γ\n"
