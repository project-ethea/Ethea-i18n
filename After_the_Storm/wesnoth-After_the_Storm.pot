msgid "Blood"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:422
msgid "Locate Zhangor"
msgstr ""

#. [set_menu_item]: id=wmi_z_combo_attacks_info
#. [lua]: sigil_image_path
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:436
#: After_the_Storm/lua/gui/combo_info_dialog.lua:111
msgid "Attack Combinations"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:460
msgid "Blood?"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:465
msgid "Yes, more blood. You might want to get used to it — there is a lot of it in the place we are headed towards."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:469
msgid "Elyssa can now summon <b>Fire Wraiths</b> on unoccupied tiles adjacent to Elynia regardless of the distance between both."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:477
msgid "If we want to have any chance of killing that bastard for good, we must stick together and try to combine our powers and attacks in different ways. Your aspect is undeniably affiliated to the path of Light; mine is Darkness. Perhaps, even without the Union, we may be able to achieve something in some form."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:482
msgid "That is why you wanted me by your side, right?"
msgstr ""

#. [message]: speaker=Elyssa
#. "Us" = Argan and Elyssa.
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:488
msgid "Yes. It is my hope that you... will not let us down."
msgstr ""

#. [transient_message]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:493
msgid "Right click on the map and choose <b>Attack Combinations</b> for information on the possible attack combinations you can use and their effects."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:502
msgid "About what Zhangor did to us..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:507
msgid "It’s a matter of time until it all vanishes from your memory — no need to dwell on it."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:512
msgid "I assume you would prefer not to discuss any of it."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:521
msgid "There is nothing for us to discuss."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:647
msgid "inferno grasp"
msgstr ""

#. [event]
#. [attack]: type=arcane
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:650
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:667
#: After_the_Storm/units/shaxthal/Warlord_Elyssa_F.cfg:42
msgid "claw of urvatha"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:656
msgid "ensnare"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:664
msgid "primal nightmare"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:673
msgid "faerie touch"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:681
msgid "flames of xia’el"
msgstr ""

#. [event]
#. [attack]: type=fire
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:684
#: After_the_Storm/units/shaxthal/Warlord_Elyssa_F.cfg:66
msgid "pyranoctum"
msgstr ""

#. [event]
#. [attack]: type=arcane
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:690
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:707
#: After_the_Storm/units/faeries/Sylvan_Warden_F.cfg:66
msgid "arcane fury"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:698
msgid "lunar wrath"
msgstr ""

#. [event]
#. [attack]: type=arcane
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:701
#: After_the_Storm/units/alien-verlissh/Control_Spire.cfg:64
#: After_the_Storm/units/alien-verlissh/Control_Spire.cfg:76
#: After_the_Storm/units/faeries/Dark_Nightshade_Fire.cfg:73
#: After_the_Storm/units/faeries/Dark_Nightshade_Fire_F.cfg:76
#: After_the_Storm/units/humans/Master_of_Darkness.cfg:58
#: After_the_Storm/units/shaxthal/Warlord_Elyssa_F.cfg:54
#: After_the_Storm/units/undead/Chaos_Cardinal_Fused.cfg:47
msgid "noctum"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:996
msgid "Xia’el, the Guardian of Earth. Her First Cycle self, to be precise. Don’t feel too intimidated by her stature, though — I very much doubt this is to scale."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1001
msgid "She is... she was a faerie? I am not sure what I was expecting."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1006
msgid "Big shoes to fill? Then again, it looks like neither of you have ever worn shoes for reasons that are surely beyond my ability to comprehend. And again, most likely not to scale."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1011
msgid "No, I mean... She looks so beautiful and dignified... but at the same time, she is... so..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1016
msgid "Mundane? By now you should know gods come in all shapes and sizes. Although anyone can play god to a sufficiently ignorant crowd."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1021
msgid "I suppose you would know about that kind of thing."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1026
msgid "You don’t need miracles, prophecies or mind control to rule over uncivilized brutes. You just need to establish clear boundaries and show your subjects the consequences for stepping out of line. Sooner or later someone will test your power regardless, so there is little point to claiming godhood unless you want to paint an even larger target on your back."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1031
msgid "Ignoring the entire Uria situation for a moment, what this world needs right now is not another false god. It just needs someone able to purge all the scum and build a new order from the ground up. If that someone happens to have god-like powers, then the job should be certainly much easier. But it does not have to be like that."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1039
msgid "You don’t need to play the role of the Guardian of Earth if that’s not what you want."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1049
msgid "I can feel the question lingering in the back of your head."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1058
msgid "When my mentor realized the true nature of the Sceptre of Fire, she asked me to wield it against the enemies of Irdya... with her dying breath."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1063
msgid "This cursed artifact is bad for your health. You must not use it ever again."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1068
msgid "I just said—"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1073
msgid "You can say anything you want, but it does nothing to change the fact that you are a creature of Light trying to wield a power that is harmful to your mind and soul."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1078
msgid "Niryone’s staff rightfully belongs to me—"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1083
msgid "I assure you, the <i>thing</i> lurking beneath the Ruby’s lustrous surface does not care for any sentimental attachment you may have to it. Your mentor’s intentions may have been noble, but if you want to save Irdya you are going to have to learn to let go of the past and not waste your potential living an eternal life of regret."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1088
msgid "If you truly want to honor her memory... if you want to make your friends’ sacrifices worth it, then it is time for you to become the Guardian of Earth we need instead of the Lady of Light who lost to her own Darkness. But if you don’t feel up to the task then you are free to stay behind, drowning in an endless ocean of sorrow for what little is left of eternity."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1160
msgid "Hm. He is not here like I expected. I suppose his intention is to make some kind of dramatic entrance later."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1165
msgid "Elynia, there is something here you should see."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1170
msgid "Move Elynia and Elyssa to (28, 20) and the immediately adjacent locations"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1322
msgid "What is that in the middle of the blood lake?"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1336
msgid "The Seed of Earth, the place from which all life on Irdya originally sprang."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1342
msgid "It is currently sealed in its chamber. There is not much that can be done with it by anyone other than the Guardian of Earth. Generally speaking, nobody is supposed to see or tamper with the thing that lays within; not even the controlling Guardian herself. That is to say, not even you."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1348
msgid "... Unless, of course, you wanted to reset life on Irdya back to the beginning. That is how the Second Cycle was started. But if you did that, then every living or non-living creature currently standing on this world would be erased from existence — even you."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1353
msgid "Doing that would destroy Zhangor for sure, but Uria is not on Irdya, and the loss would be little more than a minor inconvenience to her in the long term. But if you feel particularly selfish about your pitiful existence, this is an option for you to consider."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1362
msgid "That would be a coward’s choice, don’t you think?"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1367
msgid "Possibly. But if the guardian in question feared the absolute end of their own existence, then one could say that making the choice would take some degree of courage."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1376
msgid "What is your choice?"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1385
msgid "Do not worry, it is not a binding decision, yet."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1390
msgid "Is that the only possible use for the power stored in this place? To destroy all life in our world so it can start anew?"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1395
msgid "If Merthiaal’s cautionary story is any indication, yes. But Uria believes otherwise. She believes that the seeds can be used for other things if the aspect you control is either Life or Existence, based on the efforts of her predecessor — or the very unreliable information we have about them, anyway. But her attempts to find the seed on Urvatha have proven fruitless so far, and her patience is wearing thin. As ludicrous as it sounds, she no longer wants to find <i>just</i> the Body of the Union on Ethea."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1400
msgid "I see. Then, there is no point in doing anything with ours."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1405
msgid "I suppose. There is so much we still don’t know about our own creation..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1410
msgid "Come to think of it, we should be thankful that Delethia’s actions ensured we would not get a proper Guardian of Existence for this cycle who could turn out to be an even more powerful deranged psychopath than Uria. Well, probably. That girl, Anya... her sole existence raises many questions we thought we had already answered."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1438
msgid "... But of course. The bastard’s plans aren’t as aligned with Uria’s own as I originally thought."
msgstr ""

#. [message]: speaker=Zhangor
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1551
msgid "What a glorious day for Irdya! So, at long last, Argan’s little girl solved the puzzle!"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1580
msgid "You are a disgusting liar and a traitor, Zhangor."
msgstr ""

#. [message]: speaker=Zhangor
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1609
msgid "Excellent. That makes us equals in the eyes of the Lady of Light. Or should I now call her the Guardian of Earth on Irdya?"
msgstr ""

#. [message]: speaker=Zhangor
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1618
msgid "Ah yes, Elynia... I have not forgotten what you and Argan did to me. Do you have any idea what it feels like to live for hundreds of years in agonizing pain with your limbs scattered across the land and buried deep in the ground? Do you?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1623
msgid "You’ve got nothing to fear; this time I shall make sure <i>nothing</i> remains of your wretched body for Uria to bring back."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1628
msgid "And I shall make sure your soul is destroyed forever as well."
msgstr ""

#. [message]: speaker=Zhangor
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1633
msgid "Without the Union? Go ahead, try your best!"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1671
msgid "Demon Lord Zhangor"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1671
msgid "Angel of Blood, Scourge of Irdya"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1674
msgid "Vanquish Demon Lord Zhangor"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1681
msgid "Zhangor’s Gatekeeper powers allow him to debilitate and destroy the Energy Heart of a Guardian"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:1994
msgid "What are you trying to do now?"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2011
msgid "His body is affixed to the ground, just avoid getting hit by his lightning!"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2295
msgid "Oh, is that what we are doing now, Zhangor? I expected you to be more creative than this in a real fight."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2403
msgid "Destroying these things is increasing my power somehow..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2408
msgid "There is something about the energy released by these cores, although I have a feeling Zhangor benefits from it as well."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2518
msgid "Oh dear gods, will this ever stop?"
msgstr ""

#. [message]: speaker=Zhangor
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2527
msgid "What is the matter, Guardians? Do you fear killing those of your own kin now? Have you not become accustomed to it over the course of your pathetic lives?"
msgstr ""

#. [case]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2622
#: After_the_Storm/macros/character-defines.cfg:8
msgid "Galas"
msgstr ""

#. [case]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2642
msgid "Delanith-Isáwen"
msgstr ""

#. [case]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2648
msgid "Reghara"
msgstr ""

#. [message]: speaker=Elyssa
#. This sentence could be interpreted in two different ways; either Elyssa
#. is stating that she wouldn't want to kill the real Anya, or that she
#. does not necessarily consider the real Anya to be the real Guardian of
#. Darkness, and hence she might not hesitate in killing her. This
#. ambiguity is intentional.
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2777
msgid "I would hate to have to kill you... if you were the real Guardian of Darkness."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2784
msgid "You abandoned me..."
msgstr ""

#. [message]: speaker=Elynia
#. ‘Demon’ here refers to Zhangor.
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2792
msgid "Posing as my dearest friend will not save you from my wrath, demon!"
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2803
msgid "You left me to die..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2810
msgid "Your imitation of Argan is once again absolutely pathetic."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2817
msgid "You betrayed me..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2824
msgid "This cheap trick will not break me down this time."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2835
msgid "You killed me..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2842
msgid "I could slaughter a whole host of these stupid elves a thousand times, Zhangor. Is this all you’ve got?"
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2849
msgid "You failed to protect me..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2856
msgid "I no longer care for any of this, Zhangor. I no longer care."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2867
msgid "You are no small part of the cause of my departure from this world, you know."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2874
msgid "I could not care less about a walking joke like you."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2881
msgid "You could have prevented my death, Elynia. You could have—"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2888
msgid "No... there was nothing I could do. Stop this!"
msgstr ""

#. [message]: speaker=Elyssa
#. 'Her' refers to Elynia.
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2903
msgid "I assume you are important to her in some way?"
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2910
msgid "... You were too late to save me, Elynia. If only you had not allowed him into your heart—"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2917
msgid "NO! I don’t want to remember this! I’LL KILL YOU!"
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2928
msgid "With your power you surely could have banished those foul creatures to whence they came. Useless child."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2935
msgid "... You peered into places you shouldn’t have, Zhangor."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2942
msgid "I wonder what became of my kind under your command..."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2960
msgid "HA! I hope you enjoyed your stay with us, sweetheart."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2967
msgid "I’LL KILL YOU!"
msgstr ""

#. [message]: speaker=unit
#. Use your imagination here. See also E3S7A.2's intro text.
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2975
msgid "You must feel proud of yourself, allying with a mass-murderer like this c—"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2982
msgid "That couldn’t possibly be my own memory... I don’t think..."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:2993
msgid "For someone who wants so much to stop Uria, you are hardly any different from her kind."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3000
msgid "... You are not wrong."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3007
msgid "Taking advantage of my protégé’s heart so soon after my death... You truly are a shameless creature."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3014
msgid "I’ve had enough. You will not break me again."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3028
msgid "... Is this..."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3035
msgid "Child..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3042
msgid "M— mother...? No... NO! STOP!"
msgstr ""

#. [message]: speaker=Elyssa
#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3062
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3068
msgid "They are manifestations of Zhangor’s will — not even real shapeshifters!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3203
msgid "Brace yourself!"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3277
msgid "Wh— what is... happening to him..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3282
msgid "This is getting out of hand. We need to defeat him here and now!"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3287
msgid "... to his body..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3298
msgid "Elyssa? Are you still with me?"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3307
msgid "Is this... Is this the fate of our kind should we allow emotions to overpower our minds?"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3317
msgid "No... Zhangor devoured the heart of a Gatekeeper. He became like this of his own volition. Focus, Elyssa."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3328
msgid "FOCUS!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3426
msgid "He’s preparing to unleash a devastating attack, watch out!"
msgstr ""

#. [message]: speaker=Zhangor
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3566
msgid "... You... CANNOT..."
msgstr ""

#. [message]: speaker=Zhangor
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3613
msgid "... destroy ME..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3640
msgid "Do you think we can do it? He should not be able to focus us anymore!"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3645
msgid "No... I’m not ready yet! Just keep striking at him with all you have!"
msgstr ""

#. [message]: speaker=Zhangor
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3650
msgid "(<i>feminine voice</i>) ... I am... the Angel of Blood..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3770
msgid "You are nothing but a sad memory of who you once were. It seems Uria did not do such a good job in bringing you back from your grave."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:3777
msgid "Perhaps she was aware that you would eventually betray her. Or perhaps she did not have the same infatuation she had with Argan."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:4034
msgid "What I do know for sure..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:4067
msgid "... is that you are done. Elynia!"
msgstr ""

#. [message]: speaker=Zhangor
#. 'He' is intended to be used in the sense of a deity here.
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:4104
msgid "(<i>feminine voice</i>) ... He will come for you... at the end..."
msgstr ""

#. [message]: speaker=Zhangor
#. 'Him' also as a deity here.
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:4121
msgid "(<i>feminine voice</i>) ... the Four will not suffice to defeat Him..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:4130
msgid "Pierce into the heart of stone..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:4160
msgid "... release the soul back to the void..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:4175
msgid "... break the curse of Yarae..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:4198
msgid "... dispel the spirit from this world."
msgstr ""

#. [message]: speaker=narrator
#. [side]: type=Guardian of Earth Aradellys, id=Aradellys
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:4303
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:221
#: After_the_Storm/episode3/scenarios/13_Epilogue.cfg:60
msgid "Aradellys"
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:4305
msgid "<i>It is all well, children of Irdya. You may rest now.</i>"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:334
msgid "Rise up, Elynia-Thanadria, Guardian of Earth."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:369
msgid "You and the heiress of the First Guardian of Darkness have much work left to do."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:388
msgid "I am here."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:397
msgid "Have I mentioned yet how much I despise you?"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:420
msgid ""
"Dear Anya,\n"
"\n"
"I am sure that by the time you find the glyph containing this encoded message you will have won the battle on the surface and proven yourself worthy of your title as the Lost Guardian of Darkness on Irdya. I am also certain that Ergea will have finally revealed to you the destiny that was laid for me by the will of our creators.\n"
"\n"
"You will surely know by then as well what Uria’s plan entails for all of us. As Elorran said, Irdya is not the only world at peril.\n"
"\n"
"There are many other worlds like ours which will be similarly wiped from existence if Uria gets hold of the Body of the Union and the Seed of Life on Ethea."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:472
msgid ""
"Our mission is to stop Uria at all costs.\n"
"\n"
"We know that not all of the worlds seeded to have a Guardian have reached maturity yet. We know that Ethea might not have its own Guardian of Life yet. But it is our hope that we might be able to find her before Uria herself does, and ensure that we have a chance to stop her somehow. We know that the Guardian of Water from Norsula has arrived there, and may have already seized its seed. Our main concern for the moment is finding the real heiress of Uria on Ethea, and the Body of the Union. Unfortunately for us, we do not know much about Ethea or where to begin our search."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:485
msgid ""
"Sitting idly here on Irdya would not accomplish anything for the continuance of our existence. According to Elyssa, and the Guardian of Earth on Silida, my work here is complete. Irdya has slowly come back to life over the last few centuries, a feat which would have been impossible without my presence.\n"
"\n"
"I have seen both life and destruction take place since I was woken up from my slumber. Darkness has been an opposing force for very long, but as Mal Keshar, Anlindë, and Elyssa herself proved to me, it can also be revitalizing for a world that needs the means to protect itself from two scorching suns and the malignant forces that broke the previous balance."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:593
msgid ""
"The impenetrable darkness currently shrouding Irdya protects it from the gaze of the Seer of Uria, but if it lasts for too long, all life on Irdya will end as well.\n"
"\n"
"While Elyssa was previously responsible for this barrier within the frontiers of the Chaos Empire, the power that recently extended it far and beyond is not hers. It is yours.\n"
"\n"
"I never got the chance to speak to you about these matters because of how distant I became ever since I had to kill Argan. I thought that opening up and letting others into my life could only cause more harm to them.\n"
"\n"
"But I finally realized that this did not solve anything. By isolating myself from the world I only made things worse for everyone, something which even Elyssa could see. Perhaps she understood this better than I because of our shared curse, or maybe it was something she learned while under Argan’s protection."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:609
msgid ""
"Then again, it also appears to be natural for Guardians of Darkness to see through that invisible veil that conceals people’s fragile minds. And you are a Guardian of Darkness too — the power to peer into my feelings is a part of your self, and you were unconsciously making use of it all along.\n"
"\n"
"All this time, you tried to reach into me, and I would not let you in. But now it is all clear."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:649
msgid ""
"I am sorry, Anya.\n"
"\n"
"I am sorry for not realizing any of this before. I should have let you reach into my heart. We should have done this together like you wanted.\n"
"\n"
"Even though things did not turn out as either of us hoped, you were a good friend."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:665
msgid "A better friend than I deserved, perhaps."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:671
msgid "There are so many things you do not know yet, Anya..."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:858
msgid ""
"I am no-one to decide your fate for you, Anya, but the first thing you must do is to come at peace with your feelings and end the night.\n"
"\n"
"And once you have made a decision, you must ensure that the breach remains well guarded and protected. We do not know how to seal it yet, but if we can defeat Uria, we will surely find a way to undo the damage she has caused on Irdya and Urvatha over the years.\n"
"\n"
"And then, I will return and keep the promise I made to you."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:868
msgid "Goodbye, my friend."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/11_After_the_Storm.cfg:885
msgid "Trust your heart."
msgstr ""

#. [scenario]
#. [part]
#: After_the_Storm/episode3/scenarios/12_Destiny_part_3.cfg:4
#: After_the_Storm/episode3/storytxt.cfg:445
msgid "Destiny — Part 3"
msgstr ""

#. [event]: id=lore_entries[i + 1][1],
#. [world_entry]: id=e3s12_argan_1
#: After_the_Storm/episode3/scenarios/12_Destiny_part_3.cfg:115
#: After_the_Storm/journey/world.cfg:456
msgid "On Creation"
msgstr ""

