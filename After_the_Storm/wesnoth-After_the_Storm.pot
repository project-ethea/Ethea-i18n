#. [scenario]
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:4
msgid "Opening"
msgstr ""

#. [message]: speaker=Mal Kendria
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:124
msgid "My lady, you have finally returned! I was concerned for you, since you left without notice! What do you have there?"
msgstr ""

#. [message]: speaker=Mal Kendria
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:133
msgid "The Ruby of Fire! You retrieved it, my lady! Was the faerie elf already dead, or did you kill her yourself?"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:162
msgid "She destroyed Hekuba for us first in the elves’ valley. Naturally, she paid the price."
msgstr ""

#. [message]: speaker=Mal Kendria
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:167
msgid "So they destroyed each other? Excellent news!"
msgstr ""

#. [message]: speaker=Mal Kendria
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:178
msgid "So, what are we going to do now?"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:183
msgid "Where is Nar-hamoth?"
msgstr ""

#. [message]: speaker=Mal Kendria
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:188
msgid "I believe he’s busy battling the allied forces remaining near the Bay of Glamdrol. Should you require his immediate presence here with us, I can summon him—"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:193
msgid "That shall not be necessary. Not anymore."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:203
msgid "As Elyssa whispers an incantation never heard by Mal Kendria before, the staff she holds changes its shape into a four-bladed weapon with the glowing, unshielded Ruby at its very end. The necromancer stares in awe..."
msgstr ""

#. [message]: speaker=Mal Kendria
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:239
msgid "That’s amazing!"
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:255
msgid "But the feeling promptly vanishes as Elyssa’s eyes turn blood red. An eerie aura engulfs both former allies as the demoness advances towards the necromancer, now petrified with dread."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:282
msgid "(<i>whispering</i>) Bind the soul to stone, turn the memories to dust..."
msgstr ""

#. [message]: speaker=Mal Kendria
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:299
msgid "M-m-my lady..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:308
msgid "(<i>whispering</i>) ... erase the spirit and shed the hollow shell."
msgstr ""

#. [message]: speaker=Mal Kendria
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:317
msgid "... Elyssa... <small>I feel... <small>unwell...</small></small>"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:322
msgid "Goodbye, Kendyare."
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:336
#: After_the_Storm/episode3/scenarios/08A_Interim.cfg:2094
msgid "bind soul"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:417
msgid "Why am I still here?"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:423
msgid "Who are you within my body?"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:494
msgid "Mal Reth-Kanan"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:495
msgid "Mal Si’ah"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:496
msgid "Mal Vurapia"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:497
msgid "Mal Arkelean"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:498
msgid "Mal Zilchis"
msgstr ""

#. [event]
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:499
msgid "Mal Vrel’leru"
msgstr ""

#. [message]
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:511
msgid "The promised time has come, heiress."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode3/scenarios/00_Opening.cfg:539
msgid "So it has."
msgstr ""

