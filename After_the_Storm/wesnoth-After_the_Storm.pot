#. [side]: type=Ancient Lich, id=Mal Unroth
#. [side]: type=Chaos Razerman, id=General Penthein
#. [side]: type=Death Knight, id=General Mylean
#: After_the_Storm/episode3/scenarios/07B_Dark_Sea.cfg:76
#: After_the_Storm/episode3/scenarios/07B_Dark_Sea.cfg:121
#: After_the_Storm/episode3/scenarios/08D_Destiny_part_2.cfg:212
#: After_the_Storm/episode3/scenarios/08D_Destiny_part_2.cfg:231
