#: After_the_Storm/episode3/scenarios/04_01_Outpost_of_Hell.cfg:619
msgid "Deploy barrels of explosives to destroy the six structures supporting the central keep in Aran-Balgur"
msgstr ""

#. [objective]: condition=win
#: After_the_Storm/episode3/scenarios/04_01_Outpost_of_Hell.cfg:611
