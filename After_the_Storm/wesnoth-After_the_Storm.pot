#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:120
#: After_the_Storm/episode3/scenarios/02_01_Return_to_Raelthyn.cfg:434
msgid "Arphalad"
msgstr ""

#. [label]
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:125
#: After_the_Storm/episode3/scenarios/02_01_Return_to_Raelthyn.cfg:439
msgid "River Lorin"
msgstr ""

#. [label]
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:130
#: After_the_Storm/episode3/scenarios/02_01_Return_to_Raelthyn.cfg:444
msgid "Lake Wylven"
msgstr ""

#. [label]
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:135
#: After_the_Storm/episode3/scenarios/02_01_Return_to_Raelthyn.cfg:449
msgid "Adavyan’s Keep"
msgstr ""

#. [label]
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:140
#: After_the_Storm/episode3/scenarios/02_01_Return_to_Raelthyn.cfg:454
msgid "Danaerad"
msgstr ""

#. [label]
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:145
#: After_the_Storm/episode3/scenarios/02_01_Return_to_Raelthyn.cfg:459
msgid "Tower of Silence"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:239
msgid "Darren"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:245
msgid "Aethyncyn"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:262
msgid "Finally, the walls of Raelthyn! It’s a pity it’s too dark to see the glory of the capital city!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:267
msgid "I have been here before. Now, let’s move."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:284
msgid "I’m a humble messenger from the small village of Suthwood in the Heart Forest. We came here to meet with the Grand Council."
msgstr ""

#. [message]: speaker=Lord Durstrang
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:289
msgid "You and who else?"
msgstr ""

#. [message]: speaker=Lord Durstrang
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:305
msgid "Seize the traitor!"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:310
msgid "Traitor? Who?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:318
msgid "Exactly what in the world is going on here?"
msgstr ""

#. [message]: speaker=Lord Durstrang
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:323
msgid "You, faerie, are accused of betraying the Alliance of the Peoples of the Far North, leading an elvish faction found to be collaborating with our enemies in times of war, and disclosing vital tactical information which jeopardizes the safety of the Aragwaith country and our allies."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:332
msgid "Certainly, this must be some kind of misunderstanding... I would never shift my allegiances against what’s best for the free civilizations of Irdya!"
msgstr ""

#. [message]: speaker=Torancyn
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:344
msgid "Imprisoning her will not be necessary. Allow her to come to the Grand Council."
msgstr ""

#. [message]: speaker=Lord Durstrang
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:349
msgid "But, my lord..."
msgstr ""

#. [message]: speaker=Valen
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:365
msgid "A trial won’t be required either. She’s been framed by the enemy."
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:370
msgid "Elynia, we have been eagerly awaiting your return. It’s been a long time..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:375
msgid "Lord Arnesius, it’s good to see you again. Something terrible has happened..."
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:380
msgid "Yes, yes... Valen has told us everything, and there’s more you need to know as well. Come with us."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:385
msgid "My Lord, I— our messengers were promised an audience with the Council as well..."
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:390
msgid "That will have to wait while we discuss some war matters, but since you have come from so far protecting her, you may also come and listen."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/03_01_Unrest_in_Raelthyn.cfg:395
msgid "Very well, my lord."
msgstr ""

#. [scenario]
#. [part]
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:4
#: After_the_Storm/episode2/storytxt.cfg:93
msgid "Revelations"
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:103
msgid "We’d like to start by apologizing for our actions, or more accurately, our lack thereof. Had we understood the importance of your mission to Zocthanol we’d have sent a whole fleet with you, and Galas’ demise could have surely been avoided."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:108
msgid "I... I don’t think that would have made a great difference. The storm that caught us was a trap set up by our enemies."
msgstr ""

#. [message]: speaker=Torancyn
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:113
msgid "As soon as we got word of your plan to assault the Wesmere hive on your own, we sent a platoon in your aid, but their path was obstructed by those Shaxthal creatures, who took over the Bay of Glamdrol to the south-west."
msgstr ""

#. [message]: speaker=Torancyn
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:118
msgid "By the time the soldiers arrived, it was already too late. Not only did we not find you or the lich Mal Keshar, but the plains had completely disappeared."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:127
msgid "But... disappeared?"
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:132
msgid "Everything vanished at the center of the explosion from which you escaped. The hive, the rocks, the clouds — everything had completely disappeared, according to the reports we got. The area surrounding the massive crater turned into a vast ashy desert devoid of any traces of life, artificial or otherwise. They also said the air itself had turned thin as in the tallest peaks of the Heart Mountains. We could only assume you had also been caught in the explosion and were destroyed along with the necromancer."
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:137
msgid "With the ongoing war, we couldn’t spend much time or resources in searching for you, so we decided to seek assistance from a seer who could tell us what happened and why. That’s when we found Valen, who has been of great help to us this past year."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:146
msgid "Hold on..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:155
msgid "That isn’t possible! A year? But— it has been— it has been less than a month!"
msgstr ""

#. [message]: speaker=Valen
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:164
msgid "For you, my lady, time only continued to flow after the point you reappeared in our country’s borders, but for us, time has gone by as usual. It’s been a little over a year since the destruction of Wesmere."
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:169
msgid "We suspect you were at the very center of the explosion, which may have caused an anomaly that brought you forward in time."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:178
msgid "... Actually, it may be my own fault. I used a teleportation spell I had just learned, without mastering it first, just as I felt as though my very existence had come to an end..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:187
msgid "But the entire place vanishing doesn’t make sense... How could that happen?"
msgstr ""

#. [message]: speaker=Torancyn
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:192
msgid "There are many things we still haven’t learned about our enemies that are, perhaps, essential for putting an end to this war."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:197
msgid "Where’s Kyara? And Horo? We sent them to you after securing the Chaos outpost in Wesmere!"
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:202
msgid "I fear we have never heard those names before."
msgstr ""

#. [message]: speaker=Torancyn
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:207
msgid "Assuming they stumbled upon the same class and number of enemies as our men did, it’s very likely they didn’t make it."
msgstr ""

#. [message]: speaker=Valen
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:216
msgid "If you can provide me with more information, I may be able to find out what occurred to them, but it will take time."
msgstr ""

#. [message]: speaker=Torancyn
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:221
msgid "While Valen was trying to determine your whereabouts, new riots took place between the elves in the lands to the east. There are rumors of a certain rose-haired faerie allying herself with the leaders of the Chaos Empire, which is why you and your people have become rather unpopular amongst our peers."
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:226
msgid "The elves are once again divided and fighting their own kinsmen on the eastern border of our country, but one of the factions is clearly at an advantage thanks to their alliance with the Empire. We suspect they may be planning to invade us next, taking advantage of the tight situation on the southern borders."
msgstr ""

#. [message]: speaker=Torancyn
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:231
msgid "Furthermore, it is said a great explosion took place in Glamdrol a few days ago. We haven’t received any confirmation yet, but we fear it’s of a similar nature to the one which destroyed Wesmere. If that’s true, then we have just lost our largest western garrison."
msgstr ""

#. [message]: speaker=Elynia
#. [message]: speaker=Zynara
#. [message]: speaker=Argan
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:236
#: After_the_Storm/episode2/scenarios/07_Proximus.cfg:272
#: After_the_Storm/episode3/scenarios/08A_Interim.cfg:2921
msgid "I see..."
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:241
msgid "It’s of utmost importance that the situation in the east is cleared up. The friendly elvish faction has asked us for aid, but as it is now we are unable to gather the complete Council to come to an agreement. We currently don’t have many men to spare, so it has been suggested that you could lead a militia in order to assist them, and hopefully discover the identity of this mysterious impersonator."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:246
msgid "I think I’ve had enough experience with leading militiamen in the forests for my liking, and I highly doubt they could stand a chance against those demons and biomechanical creatures."
msgstr ""

#. [message]: speaker=Torancyn
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:256
msgid "It was never our intention to send you alone with barely-trained fighters. Amongst your messengers was one of Mal Keshar’s very own disciples, a woman by the name of Zynara. She’s willing to assist by leading a new undead horde against our enemies for you."
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:261
msgid "If you agree to help us, we will also make sure to keep you informed of any important events from the main battle front, sending you messages through Valen. You’ll also be able to communicate with us this way."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:270
msgid "There’s a very important journal we retrieved from the Chaos capital, and Mal Keshar told me before his destruction that he passed it to Kyara, the desert elf, in case neither of us would make it back from the hive. It is my hope that she and Horo are still alive somewhere, or that at the very least they passed the journal to another person. I will agree to lead the expedition on the condition that you also do your best to locate it."
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:275
msgid "That’s a fair deal, although I would first like to know what this journal contains that makes it such a great priority for you, over your reputation and people."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:280
msgid "Mal Keshar didn’t get a chance to talk with me about the contents of the journal besides the location of the hive, where the heart of Yechnagoth was supposedly stored. Before his destruction, he referred to “a greater cause, one that transcends the fate of Irdya” — I have a feeling that it’s about something he read in it. The journal was written by the Chaos Emperor himself, so the information within should be accurate and relevant for our purposes."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:289
msgid "That is, assuming the heart of the colossal creature we destroyed in Wesmere was truly Yechnagoth’s."
msgstr ""

#. [message]: speaker=Valen
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:294
msgid "I’ll do whatever it takes to find out about that journal, my lady."
msgstr ""

#. [message]: speaker=Arnesius
#: After_the_Storm/episode2/scenarios/03_02_Revelations.cfg:299
msgid "Very well, then. Tomorrow we’ll provide you with further instructions for your mission. We’ll talk with the messengers from Suthwood now."
msgstr ""

#. [scenario]
#. [part]
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:4
#: After_the_Storm/episode2/storytxt.cfg:108
msgid "Shifting Allegiances"
msgstr ""

#. [side]
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:51
msgid "team_name^Demons"
msgstr ""

#. [side]
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:94
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:117
#: After_the_Storm/episode2/scenarios/07_Proximus.cfg:199
#: After_the_Storm/episode3/scenarios/07B_Dark_Sea.cfg:247
#: After_the_Storm/episode3/scenarios/07B_Dark_Sea.cfg:258
#: After_the_Storm/episode3/scenarios/07B_Dark_Sea.cfg:271
#: After_the_Storm/episode3/scenarios/08D_Destiny_part_2.cfg:353
#: After_the_Storm/episode3/scenarios/12_Destiny_part_3.cfg:55
msgid "team_name^Shaxthals"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:179
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:816
#: After_the_Storm/episode2/scenarios/05_The_Eastern_Front.cfg:237
#: After_the_Storm/episode2/scenarios/06_The_Voyage_Home.cfg:282
msgid "Death of Zynara"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:266
msgid "It’s really been a long trip. Are we there yet?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:271
msgid "No, but we should reach Dalbloom in the middle of the night if we keep our pace and don’t stop to rest."
msgstr ""

#. [message]: speaker=Allyna
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:276
msgid "Ah, if you only knew how to use the Ruby’s power to its full extent, we could have avoided all this."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:281
msgid "Right. But—"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:290
msgid "<i>(disconcerted)</i> You can’t possibly know about the Ruby of Fire! Who are you?"
msgstr ""

#. [message]: speaker=Allyna
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:297
msgid "I’m sorry for lying to you. I really like you, but... I needed you to come here."
msgstr ""

#. [message]: speaker=Zynara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:331
msgid "An impostor!"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:336
msgid "I needed to disguise myself as a helpless human girl so I’d be allowed to travel with you and guide you to this place. I beg you to listen to what he has to say, please."
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:469
msgid "The Lady of Light."
msgstr ""

#. [message]: speaker=Tara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:474
msgid "It is an honor to meet you."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:479
msgid "What do you want from us?"
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:484
msgid "Let me be clear: we do not seek an armed confrontation with you and your forces. We just want your staff, or to be more specific, the gem decorating its top: the Ruby of Fire."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:489
msgid "You already tried this once and didn’t succeed; what makes you think this time will be any different?"
msgstr ""

#. [message]: speaker=Zynara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:494
msgid "My lady, we are wasting precious time here! Let us purge the Northlands of this blight!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:499
msgid "The power of the Ruby of Fire is too great and too evil for it to fall into the wrong hands. You fiends shall not obtain it as long as I live. I refuse to listen to any more of your drivel."
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:504
msgid "I was hoping to achieve something with a more civilized approach, but I guess diplomacy has become a thing of the past on this world as well."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:535
msgid "I’m truly sorry. It wasn’t my intention for things to come to this."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:552
msgid "What... was that?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:557
msgid "I’m not sure. There’s something very... unusual about these demons, aside from the fact that there are two faerie beings allied with them."
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:566
msgid ""
"You can now recruit undead units.\n"
"\n"
"However, because Zynara is not as powerful as Mal Keshar, her abilities have certain restrictions: you cannot recruit Vampire Bats, and you may only control a limited number of units from the <b>Ghost</b> line at a time (units in your recall list count towards the limit)."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:597
msgid "Did you all hear that?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:602
msgid "That’s the sound of bad news — Shaxthal creatures are approaching."
msgstr ""

#. [message]: speaker=Zynara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:684
msgid "They have arrived!"
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:689
msgid "Curse Uria! They have found us!"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:700
msgid "Those metallic beasts don’t seem interested in us as much as they are interested in our foes, but why?"
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:705
msgid "Lady of Light, I’d like to call a truce. These creatures are our enemies too, and we don’t really want to get involved in a slaughter."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:710
msgid "Why should my side accede? Don’t you all work for Uria?"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:715
msgid "We don’t! We are struggling <i>against</i> her!"
msgstr ""

#. [message]: speaker=Zynara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:720
msgid "My lady, those demons cannot be trusted! They must be staging a trap, posing as enemies of Uria!"
msgstr ""

#. [message]: role=doubtful faerie
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:754
msgid "I don’t know, they do seem to have a few of us amongst them. I am fairly sure our kind wouldn’t ally with demons without a very good reason."
msgstr ""

#. [message]: role=suspecting human
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:759
msgid "And what if that reason is destroying us? Your kind can’t be trusted!"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:766
msgid "My lady?"
msgstr ""

#. [message]: speaker=narrator
#. This line corresponds to Elynia's thoughts.
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:774
msgid "<i>What would Galas and Anlindë have done in this situation?</i>"
msgstr ""

#. [message]: speaker=Zynara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:779
msgid "My lady, you must decide now!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:788
msgid "Let us cooperate with these strange demons and repel the Shaxthal incursion before they infest the countryside. We’ll decide what to do about them later."
msgstr ""

#. [message]: speaker=Zynara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:793
msgid "This is ridiculous! My master must have overestimated your ability to command!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:798
msgid "Your master would have been destroyed if Galas and Anlindë hadn’t been at the command of the elvish troops. They gave him a chance to redeem himself. If it weren’t for that, none of us would be here today discussing this."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:803
msgid "Very well, let’s do this!"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:812
msgid "Repel the Shaxthal incursion"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:817
msgid "Death of Elorran"
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:834
msgid "My people! Now that Uria knows we are plotting against her, they are doomed without my guidance!"
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:855
msgid "Fort Dalbloom"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:874
msgid "Yes! We did it! We did it together!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:879
msgid "Am I right in assuming that the village of Dalbloom doesn’t truly exist anymore, and it’s just the name of an ancient stronghold from the times before the Fall?"
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:884
msgid "That’s right. We needed you to come here, away from the Alliance’s troops, and away from the Chaos forces. Or at least, we <i>thought</i> they would not be roaming around these parts. It’s alarming that their war beasts have come this far within the human country."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:896
msgid "May I know why you believe acquiring the Ruby of Fire will do good to your cause, whatever it is?"
msgstr ""

#. [message]: speaker=Tara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:901
msgid "My lady, Elorran is one of the few demon lords who refused to heed Uria’s call to war against the good peoples of Irdya. He came to me seeking support for his mission. Our intention was to contact you and destroy that artifact you hold."
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:906
msgid "According to what Anya heard, you set foot in the Kalari stronghold once, and confronted the Iron Council."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:911
msgid "More like they decided to bring us there against our will. Go on."
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:921
msgid "The many Gatekeepers were created from the ancient Guardian of Secrets, Uria’s sister. They were assigned to different locations to protect them from external interference, preventing anything from entering or leaving Inferno. Uria has figured this out, and she wants the Ruby of Fire to create a path to allow her to enter and invade a world much like yours, called Ethea. We do not know yet what her motives are — there may be something there which she could use against the few remaining gods who may oppose her."
msgstr ""

#. [message]: speaker=Tara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:926
msgid "To that end she is using Irdya to test her forces and breed a massive army of biomechanical creatures for use against those who will defend Ethea."
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:931
msgid "Although some of us think the right being <i>could</i> use the power of the Ruby to destroy or incapacitate Uria, nobody wants to risk delivering such a precious asset to her by failing in a suicidal mission. Hence we want to destroy it."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:936
msgid "We really need your help..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:945
msgid "The Ruby of Fire— this staff, originally owned by my master, the Great Sorceress Niryone... it belongs to me. I have sacrificed much keeping it away from those who could threaten the future of the peoples of Irdya. Surely we can thwart Uria’s plans in a different way."
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:950
msgid "We aren’t the only group that has stood against her rule, but we are one of the few to survive to this day. We’ve seen her real power, and only the wielder of the Union could possibly stand a chance against her — if only that power hadn’t fallen into her hands following your short incursion into her territory."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:955
msgid "What do you mean— she cannot use that power, right?"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:960
msgid "Not yet..."
msgstr ""

#. [message]: speaker=Tara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:965
msgid "What she expects to find on Ethea may be another artifact that could enable her to wield the Union."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:970
msgid "I’m not convinced destroying the Ruby is the solution. What if there’s an equivalent somewhere else on Irdya, or on another world?"
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:975
msgid "That’s a risk we’ll have to take. As things stand right now, Uria <i>is</i> more likely to obtain the Ruby than any other alternative in order to accelerate her plans."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:984
msgid "The elves... the people whom I swore to protect ages ago need me at this very moment. Let me use the power of the Ruby once more, and then we’ll make sure it will never be used again."
msgstr ""

#. [message]: speaker=Tara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:993
msgid "Elorran, I fear we won’t be able to convince her."
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:998
msgid "<i>(sighs)</i> Your tenacity has not gone unnoticed, Lady of Light. Uria knows you are a formidable enemy, albeit notably foolish at times. Do what you feel is right, and then come back to us as soon as you may so we can put an end to her plans together. Anya will go with you; her necklace will allow you to find us, no matter the distance or the time."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:1003
msgid "I will... go with her? Yes! I mean... if that’s not a problem."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:1008
msgid "We are heading towards a war zone and we welcome the support of every man or woman who can wield a weapon, cast a spell, or tend to the injured. However, I am... unsure about allowing such a young girl to accompany us."
msgstr ""

#. [message]: speaker=Tara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:1013
msgid "You might underestimate her now because making use of her magic before would have blown her cover, but I assure you, she is a most excellent spellcaster, even better than me."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:1018
msgid "(<i>blushing</i>) Ahhhh, don’t say that! I’m not that impressive, especially compared to her..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:1023
msgid "Very well, Lord Elorran. I swear I will do my best to keep the Ruby away from our enemies."
msgstr ""

#. [message]: speaker=Zynara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:1028
msgid "Dealing with demons... (<i>sigh</i>) This can’t end well..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:1033
msgid "I would like to keep our pact a secret between us. Even if the Grand Council understood, there seems to be a fair chance they could fall and provide Uria’s henchmen with information about our plans. No-one should speak of this."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:1038
#: After_the_Storm/episode2/scenarios/06_The_Voyage_Home.cfg:374
msgid "Understood, my lady."
msgstr ""

#. [message]: speaker=Zynara
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:1043
msgid "Understood..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:1048
msgid "Well, let’s continue onwards. Hopefully we won’t come across any more interruptions."
msgstr ""

#. [message]: speaker=Elorran
#: After_the_Storm/episode2/scenarios/04_Shifting_Allegiances.cfg:1082
msgid "There is an army of hostile elves approaching... Things would have worked out much better if this Lady of Light had not turned out to be such a dreadful disappointment as a leader and a tactician."
msgstr ""

