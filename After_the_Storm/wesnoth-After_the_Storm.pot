msgstr ""

#. [event]
#. [event]: id='Elynia',
#: After_the_Storm/episode1/scenarios/12_Return_to_Wesmere.cfg:836
#: After_the_Storm/episode1/scenarios/12_Return_to_Wesmere.cfg:939
