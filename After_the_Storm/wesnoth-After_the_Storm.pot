msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/09_New_Hive.cfg:266
msgid "Proceed further underground with Elynia"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/09_New_Hive.cfg:280
msgid "What is this place?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/09_New_Hive.cfg:285
msgid "According to Unarye, the valley was only slightly habitable at first; the elves had to seek refuge in the caverns during the day, while they worked to adapt the surface land to their needs at night. It appears that the Chaos Empire saw fit to turn the place into a Shaxthal hive."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/09_New_Hive.cfg:290
msgid "Although Shaxthal creatures are particularly weak against our fire, it’s essential that we remain together as we proceed further underground."
msgstr ""

#. [unit]: type=Chaos Magus, id=Kaceldyn
#: After_the_Storm/episode2/scenarios/09_New_Hive.cfg:410
msgid "Kaceldyn"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/09_New_Hive.cfg:483
msgid "What was that?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/09_New_Hive.cfg:488
msgid "I am not sure, but I fear we have wasted too much time in these caves. Whatever happens next is surely our fault."
msgstr ""

#. [scenario]
#. [part]
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:4
#: After_the_Storm/episode2/storytxt.cfg:239
msgid "The Betrayal"
msgstr ""

#. [side]: type=Hell Guardian, id=Stalygvan
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:98
msgid "Stalygvan"
msgstr ""

#. [side]: type=Gutwrencher Imp, id=Dorghazaquiel
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:123
msgid "Dorghazaquiel"
msgstr ""

#. [side]: type=Demon Warrior, gender=female, id=Elathea
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:153
msgid "Elathea"
msgstr ""

#. [side]: type=Chaos Razerman, id=Alareanthalcan
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:183
msgid "Alareanthalcan"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:393
msgid "Defeat the false Lady of Light"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:444
msgid "Another gate..."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:518
msgid "Look! It’s the impostor again!"
msgstr ""

#. [message]: speaker=Lady of Light
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:535
msgid "I have to destroy her... yes, I have to... I must not fail this time..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:544
msgid "So here you are, traitor."
msgstr ""

#. [message]: speaker=Lady of Light
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:559
msgid "I AM NOT A TRAITOR! I’LL DESTROY YOU THIS TIME!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:564
msgid "I have had enough of this — surround her and strike her down! Do not let her get away!"
msgstr ""

#. [message]: speaker=Lady of Light
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:600
msgid "No... Let me go!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:623
msgid "You and your accursed allies have been conspiring against us and the Grand Council of the Northern Peoples, sowing strife and destruction. Whoever you are, your heinous deeds make you unworthy of my mercy. You no longer deserve a place amongst elvenkind."
msgstr ""

#. [message]: speaker=Lady of Light
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:628
msgid "... Elynia... please..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:633
msgid "Leave this world <b>now</b>, and never return again!"
msgstr ""

#. [modify_unit]: id=Ivyel
#. [unit]: type=Shaxthal Infiltrator, id=Ivyel
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:663
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2460
msgid "Ivyel"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:685
msgid "(<i>confused</i>) What is this?"
msgstr ""

#. [message]: speaker=Ivyel
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:694
msgid "... Please... don’t... attack me..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:699
msgid "But... how... how is this possible?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:717
msgid "This doesn’t make sense!"
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:727
msgid "(<i>cackling</i>)"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:732
msgid "Who is that?!"
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:742
msgid "(<i>more cackling</i>) <i>What do you think of our first complete infiltrator? It took us great effort to design and build such perfection.</i>"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:751
msgid "(<i>angry</i>) I know you... You are one of the members of the Iron Council, Mal Hekuba!"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:783
msgid "Did you miss me, Elynia?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:798
msgid "... I couldn’t possibly wish harder for you and your friends’ destruction."
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:803
msgid "Ha, ha, but that’s not going to happen in your lifetime, or is it?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:871
msgid "Where are you? Stop fooling around and show yourself, you—"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:878
msgid "I understand that you must be confused and enraged after losing your friends to such a pointless cause, and traveling so far only to slaughter the same people whom you once vowed to protect!"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:893
msgid "It appears to be just an illusion..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:898
msgid "Destroying you is NOT a pointless cause!"
msgstr ""

#. [message]: speaker=narrator
#. [event]
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:904
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1506
#: After_the_Storm/macros/character-defines.cfg:79
msgid "Mal Hekuba"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:910
msgid "But of course it is! You cannot destroy us! Not without the power of the Union, anyway, which you left behind in Uria’s sacred domain when you destroyed your beloved Argan."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:914
msgid "I still have the Ruby of Fire!"
msgstr ""

#. [event]
#. "Argan’s treacherous little girl" refers to Elyssa.
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:918
msgid "That understandably attractive relic is not important for <b>me</b>. Argan’s treacherous little girl likes to think of it as if it were unique and irreplaceable, and convinced Uria of that — but in truth, it is not."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:926
msgid "What are you babbling about?"
msgstr ""

#. [event]
#. "Her finding out" refers to Elyssa.
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:930
msgid "The first set of replicas of Yechnagoth’s heart were lost when you and your pathetic lackey destroyed our base in Wesmere, but I have had plenty of time to create more here without her finding out. I am sure that together, they are as good or better than the original, and they might even be a superior substitute for your precious gem."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:938
msgid "Are you working against Uria’s will, then?"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:956
msgid "(<i>losing his temper</i>) We cannot speak to her directly! We can only do so through that treacherous wench, who keeps the Dark Lady’s heart within her for her own purposes!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:967
msgid "... We... We destroyed Wesmere... Yechnagoth’s heart wasn’t there?! What did we destroy when we..."
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:970
msgid "The energy that should have destroyed you was released from the <b>second</b> replica of her heart, and various experimental units stored in the same place. The third one still exists within our infiltrator, imbuing her with Yechnagoth’s grace and might — which is why your power is no match for hers."
msgstr ""

#. [event]
#. "Argan’s pet" is Elyssa.
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:973
msgid "Nevertheless, I do not have time to continue talking to you. Right now, I need to go to tend to some... rituals. Ivyel was created to destroy both you and Argan’s pet. Take a good glance at her perfection once she returns, for it will be your last opportunity."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:978
msgid "(<i>more cackling</i>)"
msgstr ""

#. [message]: speaker=Anya
#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:996
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1480
#: After_the_Storm/episode3/scenarios/01_Beyond_her_Smile.cfg:1520
msgid "What are we going to do now?"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1001
msgid "Those bastards can’t get away with this! My lady, we must do something!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1010
msgid "I don’t think we have the power necessary to destroy the artifacts that Mal Hekuba is going to use to..."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1015
msgid "Of course we do! We didn’t come all the way from the northern lands risking that blasted Ruby for nothing! Whatever that lich is going to do, it will destroy us all if we don’t stop him now!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1020
msgid "The last time we fought against that power, I lost a friend, and the vast plains of Wesmere vanished with his remains..."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1025
msgid "Any course of action at this point will inevitably lead to someone’s destruction, but I’m sure we can do it this time! If the lich is going to create a... path to Inferno, as Elorran said, perhaps we can cause it to collapse at the other side!"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1030
msgid "I don’t truly understand most of this nonsense about hearts and Yechnagoth, but I reckon we need to destroy the lich and the impostor — and we can’t do that without your help, Elynia."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1035
msgid "We don’t have much time! That thing we just fought could be back at any moment!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1044
msgid "I appreciate your support... I don’t think I could have come this far alone. And I don’t want to force you to follow me..."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1049
msgid "Of course not! We are your friends!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1054
msgid "Let’s find that foul fiend and destroy him once and for all."
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1059
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1441
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:434
msgid "Proceed further underground with Elynia to find Mal Hekuba"
msgstr ""

#. [message]: speaker=Alareanthalcan
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1216
msgid "They are getting closer to the control chamber! Get them, quickly!"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1221
msgid "I don’t like the sound of that..."
msgstr ""

#. [message]: speaker=Stalygvan
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1275
msgid "You! You can’t stop our master! You can’t—"
msgstr ""

#. [event]: id=Kardas
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1292
msgid "Kardas"
msgstr ""

#. [message]: speaker=Kardas
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1306
msgid "My lady! At last, I found you! I know where the lich is!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1311
msgid "Speak."
msgstr ""

#. [message]: speaker=Kardas
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1335
msgid "The catacombs below guard an artifact of some sort. Nobody knows exactly what it is, but we know the entrance is protected by a gate controlled by three crystals found near this guard post."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1346
msgid "Let’s find those crystals, then."
msgstr ""

#. [event]: id=Kardas
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1355
msgid "Locate and activate the three control crystals to open the central gates"
msgstr ""

#. [message]: speaker=Elathea
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1373
msgid "May Uria punish you all for this—"
msgstr ""

#. [message]: speaker=Dorghazaquiel
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1385
msgid "Nooooaaagh... it hurts!!!"
msgstr ""

#. [message]
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1402
msgid "The beast’s body is dissolving into slime!"
msgstr ""

#. [message]: speaker=Alareanthalcan
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1459
msgid "Even though I have fallen, you are no match for my master’s power!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1464
msgid "We’ll see about that very soon."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1490
msgid "What in blazes is that creature?!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1495
msgid "Don’t meet its gaze! It will drain your life force!"
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1520
msgid ""
"The whirlpool is overflowing with an unusual energy.\n"
"\n"
"A dark energy."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1539
msgid "Hm, what is this? There seems to be something at the bottom..."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1544
msgid "I wouldn’t get too close if I were you. It could be another one of those biomechanical abominations."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1549
msgid "I mean, it doesn’t look like there are any creatures in the water anyway. (<i>touches the water</i>)"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1558
msgid "Anya, what are you doing?"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1563
msgid "Er, ummm... nothing! I just— <b>AAAAAAAAAAAHHHH!!!</b>"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1584
msgid "Elynia and Durvan"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1586
msgid "ANYA!!!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1605
msgid "No... please don’t do this to me—"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1611
msgid "I am all right!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1617
msgid "... Anya? Where are you???"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1639
msgid "I don’t really know? The current dragged me into a small chamber that seems to be right below where you are. I think I may be able to get back to you? Good thing I can swim."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1649
msgid "Yes, you can swim... but I cannot. You should return to us before anything happens to you down there."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1659
msgid "Nah, it will be fine. Don’t worry about me. I am just going to do a little exploring down here and come back."
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1666
msgid "Anya can return to the main area by going back through the whirlpool, in a similar fashion to how units can teleport between villages they already control."
msgstr ""

#. [transient_message]
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1697
msgid "Mermaid’s Pendant"
msgstr ""

#. [transient_message]
#. The sudden shift to second person narration is quite
#. intentional. You will see more of this throughout Episode 3.
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1701
msgid ""
"This beautiful pendant made from an iridescent conch shines all the colors of the rainbow under the light cast on the altar. The spectacle is absolutely mesmerizing, but you figure you need to find out what uses this marvelous item has.\n"
"\n"
"Unfortunately, there is absolutely nothing engraved on it or the altar that could possibly be of help to you. How disappointing, you think. Maybe this little adventure was an absolute waste of time. But something in your mind tells you that perhaps you are supposed to wait for the right person and the right opportunity to make use of the artifact. When is that going to be, you wonder? The answer eludes you.\n"
"\n"
"You should probably go back to Elynia for the time being."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1731
msgid "So, how was your little adventure?"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1736
msgid "Well, I found this on an altar! It’s so shiny!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1741
msgid "... A seashell pendant? How did it find its way here, so far from the ocean?"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1746
msgid "It could be some kind of keepsake the elves brought here when they first arrived?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1751
msgid "That is the most likely answer, yes."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1756
msgid "Do you think it has magical properties? Maybe I can summon water creatures! Or water... projectiles of some kind? Perhaps I can shoot bubbles!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1765
msgid "No... I am afraid there is no magic in this pendant at all."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1770
msgid "Wh... what."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1779
msgid "Did I actually just risk my life fighting that... giant... spider... to obtain a completely mundane pendant?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1784
msgid "So it would seem."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1793
msgid "... Oh well... At least it’s pretty! I’m going to keep it if you don’t mind."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1798
msgid "Sure. Just... don’t do that again, please? You had us really worried for a moment there."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1803
msgid "I know, I’m sorry..."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1828
msgid "It is probably too late to stop that lich by now..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/10_The_Betrayal.cfg:1839
msgid "Make haste!"
msgstr ""

#. [scenario]
#. [part]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:4
#: After_the_Storm/episode2/storytxt.cfg:248
msgid "A Final Confrontation"
msgstr ""

#. [side]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:47
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:100
msgid "team_name^Mal Hekuba"
msgstr ""

#. [side]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:117
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:182
msgid "team_name^Chamber Guards"
msgstr ""

#. [unit]: type=Demon Zephyr, gender=female, id=Azalia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:137
msgid "Azalia"
msgstr ""

#. [unit]: type=Demon Zephyr, gender=male, id=Rhadiarch
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:151
msgid "Rhadiarch"
msgstr ""

#. [unit]: type=Demon Zephyr, gender=female, id=Galaviel
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:166
msgid "Galaviel"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:448
msgid "This goes deeper and deeper—"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:457
msgid "... I fear we don’t have much more time. Just where in this accursed place are you, Hekuba?"
msgstr ""

#. [unit]: type=Chaos Lorekeeper, id=Jarlean
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:602
msgid "Jarlean"
msgstr ""

#. [unit]: type=Chaos Arbalestier, id=Terryl
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:626
msgid "Terryl"
msgstr ""

#. [value]: id=E2S11_note_2
#. [world_entry]: id=E2S11_note_2
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:714
#: After_the_Storm/journey/world.cfg:173
msgid "Personal Note #601: Loyalties"
msgstr ""

#. [value]: id=E2S11_note_3
#. [world_entry]: id=E2S11_note_3
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:718
#: After_the_Storm/journey/world.cfg:192
msgid "Personal Note #607: Identity"
msgstr ""

#. [option]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:738
msgid ""
"- Line 1 nominal\n"
"- Line 2 nominal\n"
"- Line 3 under maintenance\n"
"- Line 4 over capacity\n"
"- Line 5 offline"
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:809
msgid "The earth shakes."
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:853
msgid "Move Elynia to the central chamber"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:958
msgid "Be careful. I’m sure he is in this chamber, somewhere..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:989
msgid "Most likely on that tall platform at the center. We need to get up there somehow."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:998
msgid "What’s that noise?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1055
msgid "... That energy... It’s the same..."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1060
msgid "Elynia? What’s happening?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1069
msgid "... A dark energy emanates from those spires... It’s the same energy that was released in Wesmere when we destroyed the creature within the hive. "
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1074
msgid "How should we destroy them?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1079
msgid "Search the chamber — there must be some mechanism controlling them."
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1090
msgid "Explore the central chamber"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1306
msgid "Welcome to your end, heathens!"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1394
msgid "What kind of evil magic is this?"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1399
msgid "Is he... fused with one of the spires?"
msgstr ""

#. [message]: speaker=Elynia
#. "Your leader" refers to Elyssa.
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1405
msgid "What do you expect to achieve by creating a new portal to Inferno with your new-found powers? Your troops are falling one by one under the might of the northern peoples’ alliance, while you decided to rebel against your leader in this dead land?"
msgstr ""

#. [message]: speaker=Mal Hekuba
#. "her" refers to Elyssa, again.
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1411
msgid "Ha, ha, ha, ha! Don’t forget that your shortsightedness is the chief cause of your friends’ demise, foolish creature. The power I control now is too great, even for her."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1416
msgid "What if you don’t truly control it? You said you cannot speak to Uria directly — what if her will is <i>your</i> destruction?"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1421
msgid "Insolent girl! You shall all die!"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1429
msgid "YOU SHALL ALL DIE NOW!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1485
msgid "Everyone, stay away from the spires and the portal! I must think of something..."
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1489
msgid "The portal grows in size every turn, taking adjacent ground hexes with it"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1490
msgid "Unless adjacent to a spire, road hexes cannot disappear"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1491
msgid "Units incapable of flight will die should the ground below them disappear"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1492
msgid "While the portal is active, faeries and shydes <b>cannot</b> fly over unwalkable terrain"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1497
msgid "Survive until the end of turns"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1506
msgid "Undying Elder of Yechnagoth’s Iron Council"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1701
msgid "There’s no use in attacking those structures — the energy they release in retaliation could kill us all!"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1873
msgid "Attacking me is futile!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1895
msgid "The more time passes, the more energy fills the place and binds our worlds together. I must go and try to destroy that lich by myself."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1902
msgid "Elynia? No! If you go he will—"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1907
msgid "I am well aware, but I’m also the only one who can wield this staff and not become corrupted by the power of the Ruby. Using it to vanquish this evil... if my own sacrifice is necessary, I will gladly accept my fate. There’s nothing left in Irdya for me now, and there will certainly be nothing for you all if this fiend succeeds."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1916
msgid "I— I—"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1931
msgid "You cannot go with me, for someone must survive the ordeal to pass the news on to our allies. You are a very smart girl, and I’m sure you all will be able to escape together with your power."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1942
msgid "I must go now."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1949
msgid "Elynia, my lady... Good luck!"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1954
msgid "(<i>tearful</i>) Elynia! Don’t die up there! Please!"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1963
msgid "(<i>muttering to herself</i>) I can only try."
msgstr ""

#. [object]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1972
msgid "Darkness Flight"
msgstr ""

#. [object]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:1973
msgid "Elynia is now able to fly unimpeded over the portal."
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2040
msgid "Attack Mal Hekuba with Elynia"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2070
msgid "And just what are you doing now?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2075
msgid "I’m going to destroy you!"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2143
msgid "How pathetic."
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2164
msgid "Have you not learned anything after your friends’ vain sacrifices, Elynia? Have you not learned to GIVE UP?"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2237
msgid "ELYNIA!"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2242
msgid "Why won’t you just accept your fate and <b>DIE</b>?!"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2254
msgid "We must do something!"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2259
msgid "If Elynia herself doesn’t have the power to destroy that lich, I don’t think there’s anything we can do about it..."
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2264
msgid "Survive until the opportunity to destroy Mal Hekuba presents itself"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2283
msgid "It’s too late to stop me!"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2293
msgid "There’s absolutely <i>nothing</i> you can do!"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2408
msgid "Have you had enough already?"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2413
msgid "No?"
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2421
msgid "<i>... Don’t forget that you are here fighting for a greater cause...</i>"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2426
msgid "... I..."
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2435
msgid "Stupid little vermin..."
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2503
msgid "Ah, Ivyel, at long last! It’s good to see you again... This pitiful creature is hindering me. Could you sweep her away for me?"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2544
msgid "... What’s this?"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2555
msgid "... I cannot be defeated by the likes of you..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2586
msgid "... I am the Lady of Light, Protector of the Elves of Irdya..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2595
msgid "... even without my former power, I shall destroy you..."
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2600
msgid "Of course not. TAKE HER DOWN!"
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2609
msgid "What’s she going to do? Does she have a plan?"
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2614
msgid "I am not sure. It appears she wants to attack the infiltrator creature..."
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2618
msgid "Destroy Ivyel"
msgstr ""

#. [event]
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2629
msgid "“Ivyel”"
msgstr ""

#. [event]
#. Rev.: Revision
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2631
msgid "Biomechanical Infiltrator Unit 01 (Equipment Type C, Core MTAL-03 Rev. 2)"
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2649
msgid "This is <i>your</i> end, Mal Hekuba..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2698
msgid "... Irdya is not yours to destroy!"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2716
msgid "AAAAAAAARRGH!"
msgstr ""

#. [message]: speaker=Mal Hekuba
#: After_the_Storm/episode2/scenarios/11_A_Final_Confrontation.cfg:2763
msgid "WHAT HAVE YOU DONE?"
msgstr ""

#. [side]
#. [side]: type=Boss Guardian of Darkness Elyssa
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:42
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:57
#: After_the_Storm/episode3/scenarios/07A_Dark_Fire_part_2.cfg:57
#: After_the_Storm/episode3/scenarios/08A_Interim.cfg:35
#: After_the_Storm/episode3/scenarios/08C_Breakdown.cfg:125
msgid "team_name^Elyssa"
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:194
msgid "Severely injured, Elynia manages to escape from the underground base as the energy destroys Mal Hekuba and his minions."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:235
msgid "Ungh..."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:245
msgid "Just as she tries, to no avail, to stand up, Elynia senses the presence of creatures of some sort amidst the dense night fog."
msgstr ""

#. [message]: speaker=narrator
#. [part]
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:271
#: After_the_Storm/episode3/storytxt.cfg:445
msgid "And then..."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:309
msgid "... darkness."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:319
msgid "<i>I cannot bring myself to kill someone so much weaker than I.</i>"
msgstr ""

#. [message]: speaker=narrator
#. The implication is not only that Elynia is hearing words she
#. herself uttered once (near the end of IftU), but also that
#. she is hearing them in her voice, possibly as a result of a
#. head trauma-induced hallucination.
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:334
msgid "<i>Are those my words?</i>"
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:344
msgid "(<i>in a seductive tone</i>) <i>It would be unfair... and cruel...</i>"
msgstr ""

#. [message]: speaker=narrator
#. See the previous implication. This is why the line is "who
#. are you?" and not "who is there?".
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:357
msgid "<i>Who are you?</i>"
msgstr ""

#. [message]: speaker=narrator
#. Take note of the description. She continues to do this for
#. the remainder of the scene.
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:383
msgid "The demoness stared directly into her eyes, with a deeply unsettling, emotionless expression."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:393
msgid "Elynia was still unable to stand up and defend herself."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:399
msgid "As Elyssa bent down to reach her head, Elynia prepared for the inevitable."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:409
msgid "But instead of dealing the killing blow, Elyssa stroked the elf’s hair — the expression on her face unchanged — and continued to speak in a soft tone of voice."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:418
msgid "I don’t want to kill you."
msgstr ""

#. [message]: speaker=Elyssa
#. "He" refers to Argan.
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:428
msgid "You spared my life, just like he did."
msgstr ""

#. [message]: speaker=Elyssa
#. No, she isn't sorry. Unfortunately there's pretty much no
#. way to convey this in direct written speech, so we only have
#. the previous description of an emotionless expression. You
#. could say she is being sardonic about it all; after all, she
#. also knows for a fact that Elynia won't actually step aside.
#. Finally, the person who "didn't give [her] a choice" is
#. Uria.
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:444
msgid "I’m truly sorry about your friends. She didn’t give me a choice. Now, just let me take what I need, and die in peace if you need to — otherwise, don’t inconvenience us anymore and I’ll never cause you any harm again."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:458
msgid "Elynia felt the exchange could have taken place at a better time, and not during such a terrible display of weakness."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:473
msgid "<i>... Why... why do you do this...</i>"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:482
msgid "... Because it’s all I have left, my dear."
msgstr ""

#. [message]: speaker=Elyssa
#. Still sardonic.
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:527
msgid "... And thank you for getting rid of that bothersome upstart for me."
msgstr ""

#. [message]: speaker=narrator
#: After_the_Storm/episode2/scenarios/12_Fate.cfg:553
msgid "<i>... Elynia?</i>"
msgstr ""

#. [page]
#: After_the_Storm/episode2/storytxt.cfg:8
#: After_the_Storm/episode3/storytxt.cfg:8
msgid "<b>If you have not completed Episode I of <i>After the Storm</i>, you should not play this episode yet.</b>"
msgstr ""

#. [part]
#. The lines consisting of a single em dash represent a long pause.
#: After_the_Storm/episode2/storytxt.cfg:23
msgid ""
"—\n"
"\n"
"—\n"
"\n"
"—"
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:30
msgid ""
"—\n"
"\n"
"—\n"
"\n"
"“The light..."
msgstr ""

#. [part]
#. Warm as in warm colors.
#: After_the_Storm/episode2/storytxt.cfg:39
msgid ""
"A familiar light...\n"
"\n"
"It was the warm light of the second sunset."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:44
msgid ""
"Where was I?\n"
"\n"
"I found myself in the middle of a glade, lying on the ground. My entire body was in pain and my clothes were considerably scorched, but somehow... I had survived."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:49
msgid "It took me some time to recover from the initial stupor and remember what had happened moments before. The terrifying feeling of my soul fading away, the crumbling underground hive, my despair as I struggled to find a way back to the surface... and my only remaining friend..."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:52
msgid ""
"Malin Keshar.\n"
"\n"
"His dark existence full of resentment and spite, an eternity spent as a harbinger of death and destruction... an eternity at long last come to an end, but not without first proving his worth against the Chaos Emperor and the creature in possession of Yechnagoth’s heart.\n"
"\n"
"Oh, who would have ever thought that I would grieve for he whom I was once destined to eliminate, or that his final death would be one befitting a hero?"
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:60
msgid ""
"As my memory became clearer, I realized I had cast the teleport spell at the last moment, as if by instinct, in a desperate attempt to escape to the surface. However, a quick glance at my surroundings revealed that it didn’t work quite as I had intended; instead, it had taken me far away from the cursed plains of Wesmere.\n"
"\n"
"But how far, exactly?"
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:72
msgid ""
"There were very few friendly faces amongst the villagers. From what I heard during my stay, they feel forsaken by the Grand Council, which has been too preoccupied with the war against the Chaos Empire to heed civilian demands. The unforgiving weather and the growing scarcity of resources to sustain their settlement has made these men and women increasingly bitter about the state of affairs.\n"
"\n"
"I can’t help but wonder how the Alliance has fared in battle ever since we left their lands."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:83
msgid ""
"This Allyna girl seems oddly over-enthusiastic about everything in spite of the difficulties she encountered before we found her. To say that it has been a long time since I last had the opportunity to talk to someone like that would be a great understatement.\n"
"\n"
"Sadly, her cheerful demeanor is not enough to dispel the shadows that have followed me wherever I go since Galas’ death; nor does it do anything to keep me from remembering Malin and his habit of trying to make the most fun of any situation."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:88
msgid ""
"For somebody who has lived for so long, it’s hard to see the world in the same light as young people do. Nowadays I can barely remember those times of blithe disregard for responsibility, my romantic escapades, and the misguided notion that we had all the time of the world for ourselves.\n"
"\n"
"Sometimes, I wish I could get rid of this burden."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:94
msgid "Before dying, my master told me that the true power of the Ruby of Fire would become crucial for the fate of our world, and that I must make sure it’s never misused by anyone again. It never occurred to me that her words could turn out to be more than a pain-induced delusion."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:103
msgid ""
"And so we left for the eastern marches, with a renewed and clear purpose.\n"
"\n"
"Surprisingly enough, Durvan and some of the other hunters from the Heart Forest agreed to participate in our expedition. Allyna offered her help as well, providing us with a safe route to follow, incidentally crossing through her village."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:109
msgid "We proceeded as swiftly as we could, hoping for an uneventful journey — given the nature of our mission, expending our energy before reaching the elves could prove disastrous later on."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:118
msgid ""
"Had the circumstances been only slightly different, I would have been much more reluctant to converse with the outcast demon lord; in fact, I would have been more likely to attack without even giving him a chance to speak.\n"
"\n"
"That girl, Anya. It was her curious personality, and her sincerity and admiration for me that led me to try my late friend’s approach to dealing with a similarly unusual enemy. I thought that such a person could not possibly side with the cruel creatures working for Uria — not that faeries of the deep forest like her are known to side with anyone at all."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:123
msgid ""
"But, did I make that choice for her or for me? Perhaps I merely wanted someone by my side to whom I could relate, someone who personified the bright and hopeful part of me that died with Argan.\n"
"\n"
"Perhaps... I didn’t want to face the possibility of having to kill that part of me a second time."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:128
msgid "All this seems so absurd as I write it. Sometimes I wonder why I let Galas convince me to write another journal."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:132
msgid "After a couple of days, we finally arrived at the frontier. Unfortunately, we’d soon learn that the Council’s fears had become more than mere speculations."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:141
msgid "Unarye told us to follow her guards into a nearby forest where some of the allied elves had just set up camp. I could tell by her grave expression that she bore bad news. It took her almost the entire afternoon to make time for speaking to us."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:150
msgid ""
"I continued to feel uneasy about the decision for some time. Leaving both the Grand Council and Elorran awaiting our return for so long...\n"
"\n"
"According to Valen, the Council understood the urgency of the situation and the importance of our mission for the elves. Unfortunately, the same couldn’t be said for the demon lord; it took Anya her best effort to persuade him to let us take the Ruby of Fire to enemy territory."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:155
msgid ""
"It is decidedly not easy to deal with both the Council and my people without telling them of our pact with Elorran. What concerns me the most is the possibility that one of our men might accidentally or deliberately divulge information pertaining to the subject. This is not like every other time I have had to keep a secret for a greater good — alone.\n"
"\n"
"It does raise the question of whether I have chosen my allies prudently or am making a big mistake."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:161
msgid "Then again, Malin would insist that the existence of that accursed artifact is a big mistake by itself."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:170
msgid ""
"After the events in Gralseth, the journey across the desert turned into a nightmare. We had to be wary of every single thing we saw, no matter how small or innocuous it seemed. Our enemies could be anywhere, everywhere. We were walking into a trap by our own choice... No, it was <i>my</i> choice.\n"
"\n"
"Even without taking our enemies into account, traversing the vast dry plains was a highly dangerous thing to do. While it wasn’t possible for us to lose track of our destination for long with our maps and Valen’s indications, the stifling heat during the day, frequent sandstorms, and lack of water sources could have resulted in catastrophic losses."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:175
msgid ""
"Eventually, it became evident that our enemies didn’t want to take risks in the hostile sands either. Aside from a few armed encounters with the natives, we found very little opposition on our way.\n"
"\n"
"At the end, we reached a small oasis near some ruins."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:181
msgid "We had reached the northern defense line of the valley Telchior named after me."
msgstr ""

#. [part]
#. Condenser/capacitor.
#: After_the_Storm/episode2/storytxt.cfg:191
msgid ""
"The Ruby of Fire. A great energy condenser of uncertain origin, used by humans throughout Irdya’s history as both a symbol of power and a catalyst to exert control over all within their reach, and beyond. Through abuse of this artifact, our world was made susceptible to corrupting influences from other realms.\n"
"\n"
"Now that we are without a necromancer, using its dangerous power to command the undead minions left behind by Zynara is the only option we have left if we want to have a chance to vanquish the impostor despite our small numbers. But, who is she in truth?"
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:196
msgid ""
"Up to this point I have broken more rules than is acceptable for any elf, or human.\n"
"\n"
"First, the Ruby. Then I chose Argan, of all people, to be my ally and lover, and asked him to help me learn to use the artifact’s power more effectively. I asked him to teach me the basics of this forbidden magic, and only my fear deterred me from delving deeper — had it not, I probably wouldn’t be here writing these words."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:201
msgid ""
"Then, I joined the Empire of Wesnoth as an advisor, against the wishes of the Ka’lian, who only realized the benefits much later. But eventually, I was betrayed by the humans; I turned my back on the world and unknowingly left my kinsmen in Wesmere to be caught in Zhangor’s trap at the onset of the end.\n"
"\n"
"Perhaps if I hadn’t broken so many rules before, none of that would have ever come to pass."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:206
msgid "Our alliance with Mal Keshar in this era was not my choice, however. Galas and Anlindë knew well what it entailed, and opted for a desperate solution to a desperate situation. But now... I appear to be following the same logic, commanding the dead with a power that was meant to be purged from this world long ago. It seems selfish, and others could misinterpret my actions."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:209
msgid ""
"I no longer command the Union, and now I am about to confront our enemy while leading my own army of darkness.\n"
"\n"
"It would be no exaggeration to say that I am, in fact, another impostor."
msgstr ""

#. [part]
#: After_the_Storm/episode2/storytxt.cfg:215
msgid ""
"Some day all this will be over, and I will be able to distance myself from civilization again.\n"
"\n"
"But for now, I must fight. And afterwards, I must recover that journal."
msgstr ""

#: After_the_Storm/episode3/characters.cfg:47
msgid "Irylean"
msgstr ""

#: After_the_Storm/episode3/characters.cfg:76
msgid "General Bardyl"
msgstr ""

#: After_the_Storm/episode3/characters.cfg:119
msgid "Cron"
msgstr ""

#: After_the_Storm/episode3/characters.cfg:134
msgid "Ergea"
msgstr ""

#: After_the_Storm/episode3/characters.cfg:148
msgid "Naiad"
msgstr ""

#: After_the_Storm/episode3/characters.cfg:260
msgid "Certain high-level units in this campaign under your control — such as Elynia and Anya — have special <b>After Maximum Level Advancements (AMLAs)</b>. You can learn more about those by right-clicking applicable units and choosing the <b>Unit Advancements</b> option."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode3/deaths.cfg:72
msgid "No! Elynia, please!"
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:84
msgid "No... Elynia... save me..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/deaths.cfg:89
msgid "No... NO!"
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:100
msgid "I guess... I will never see my home again..."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:111
msgid "It is over for me..."
msgstr ""

#. [message]: speaker=unit
#. He's referring to Galas and Mal Keshar.
#: After_the_Storm/episode3/deaths.cfg:123
msgid "I couldn’t... I couldn’t avenge the elf friend and the scary lich..."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/deaths.cfg:129
msgid "I should have seen this coming... I’m sorry we failed to protect you, friend. I’m sorry..."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:140
msgid "I don’t think I— ARGH!"
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:151
msgid "This couldn’t be more untimely... ugh..."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:162
msgid "Alas, I thought I’d... recover Aran-Balgur... before... this..."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:174
msgid "Oh, Elynia... I wish... you could be... with me now..."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:185
msgid "... I knew this was... a terrible idea... heh...."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode3/deaths.cfg:190
msgid "No! It didn’t have to end like this!"
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:201
msgid "Alas... nobody will mourn my passing..."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:212
msgid "No... we were so close to the end..."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode3/deaths.cfg:218
msgid "I cannot believe it... I’m sorry, Elynia. I could’ve done better, I could’ve saved him..."
msgstr ""

#. [message]: speaker=Durvan
#: After_the_Storm/episode3/deaths.cfg:223
msgid "It’s not your fault, Anya. At least he died a hero — better than can be said for most goblins who just end up as cannon fodder for— Irylean what are you doing??"
msgstr ""

#. [message]: speaker=Irylean
#: After_the_Storm/episode3/deaths.cfg:228
msgid "Master Mal Keshar once told me that the goblin’s life-long wish was to rise again as a fearsome undead champion."
msgstr ""

#. [message]: speaker=Anya
#: After_the_Storm/episode3/deaths.cfg:233
msgid "No!!! I am <b>not</b> allowing you to do this! I never had the chance to meet the guy but I have a feeling he wasn’t being serious when he said that."
msgstr ""

#. [message]: speaker=Irylean
#: After_the_Storm/episode3/deaths.cfg:238
msgid "Very well, if you say so... I’ve got to admit I am not very good at raising the recently deceased anyway."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:249
msgid "I failed you all..."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:263
msgid "This battle is not mine to fight. Farewell, Anya."
msgstr ""

#. [message]: speaker=unit
#: After_the_Storm/episode3/deaths.cfg:274
msgid "Cron falls... and bids the storm lady... farewell..."
msgstr ""

#. [message]: speaker=Ergea
#: After_the_Storm/episode3/deaths.cfg:279
msgid "No! This... this was not supposed to happen! Cron!"
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/deaths.cfg:288
msgid "Such an incompetent fool. I should have known she would be useless in the end."
msgstr ""

#. [message]: speaker=Elynia
#: After_the_Storm/episode3/deaths.cfg:297
msgid "Even with her greater experience... This is hopeless..."
msgstr ""

#. [message]: speaker=Elyssa
#: After_the_Storm/episode3/deaths.cfg:306
msgid "I should have known this would fail so horribly in the end..."
msgstr ""

