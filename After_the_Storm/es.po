#. [event]
#: After_the_Storm/episode1/scenarios/12_Return_to_Wesmere.cfg:793
msgid "Find the Shaxthal hive entrance and proceed underground"
msgstr "Encuentra la entrada a la colmena Shaxthal y avanza al subsuelo"

#. [event]
#. [event]: id='Elynia',
#: After_the_Storm/episode1/scenarios/12_Return_to_Wesmere.cfg:798
