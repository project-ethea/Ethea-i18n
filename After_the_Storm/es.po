#. [terrain_type]: id=blood_ford
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:4
#: After_the_Storm/episode3/storytxt.cfg:427 After_the_Storm/terrain.cfg:8
#: After_the_Storm/terrain.cfg:19
msgid "Blood"
msgstr "Sangre"

#. [event]
#: After_the_Storm/episode3/scenarios/10_Blood.cfg:422
msgid "Locate Zhangor"
msgstr "Localizar a Zhangor"

#. [set_menu_item]: id=wmi_z_combo_attacks_info
