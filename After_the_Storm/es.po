msgstr "Ángel de Sangre"

#. [attack]: type=arcane
#: After_the_Storm/units/demons/angel-of-blood/01_blood_core.cfg:35
#: After_the_Storm/units/demons/angel-of-blood/01_blood_core.cfg:49
msgid "eye of delethia"
msgstr "ojo de delethia"

#. [attack]: type=arcane
#: After_the_Storm/units/demons/angel-of-blood/10_angel.cfg:40
#: After_the_Storm/units/shaxthal/Shaxthal_Deathbringer_Alpha.cfg:35
msgid "soul spear"
msgstr "lanza del alma"

#. [attack]: type=arcane
#: After_the_Storm/units/demons/angel-of-blood/10_angel.cfg:53
#: After_the_Storm/units/demons/angel-of-blood/20_gatekeeper.cfg:60
#: After_the_Storm/units/shaxthal/Shaxthal_Deathbringer_Alpha.cfg:48
msgid "blood storm"
msgstr "tormenta de sangre"

#: After_the_Storm/units/demons/angel-of-blood/20_gatekeeper.cfg:8
